DirectoryIndex index.html
AddDefaultCharset UTF-8

# Redirection HTTP → HTTPS (à activer quand SSL est configuré)
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Redirection sans www → avec www
RewriteEngine On
RewriteCond %{HTTP_HOST} ^axeltagrou\.fr$ [NC]
RewriteRule ^(.*)$ http://www.axeltagrou.fr/$1 [R=301,L]

# ── Sécurité ──
# Bloquer le clickjacking
Header always set X-Frame-Options "SAMEORIGIN"

# Bloquer le MIME sniffing
Header always set X-Content-Type-Options "nosniff"

# Activer le filtre XSS du navigateur
Header always set X-XSS-Protection "1; mode=block"

# Contrôler les informations de référence
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# Désactiver les fonctionnalités sensibles
Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

# Masquer la version du serveur
ServerSignature Off

# Bloquer l'accès aux fichiers sensibles
<FilesMatch "\.(htaccess|htpasswd|ovhconfig|json|xml|log|git)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Autoriser sitemap.xml et robots.txt
<Files "sitemap.xml">
    Order allow,deny
    Allow from all
</Files>
<Files "robots.txt">
    Order allow,deny
    Allow from all
</Files>

# Cache navigateur
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
